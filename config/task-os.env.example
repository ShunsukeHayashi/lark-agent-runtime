# ============================================================
# Task OS — Meegle (Lark Project) 連携設定
# ============================================================
# このファイルを ~/.larc/config.env に追記するか、
# 別ファイルとして ~/.larc/task-os.env に配置して source する。
#
# agents.yaml の task_os セクションと対応。
# 環境変数が設定されている場合、agents.yaml より優先される。
# ============================================================

# ── Meegle 空間設定 ─────────────────────────────────────────────────
# Lark Project の project_key（空間URL末尾のID）
LARC_MEEGLE_PROJECT_KEY=""

# ワークアイテム種別（通常 "story"）
LARC_MEEGLE_WORK_ITEM_TYPE="story"

# テンプレートID（create_workitem 時に必須）
LARC_MEEGLE_TEMPLATE_ID=""

# 空間名・タイプ名（MQLのFROM句で使用）
LARC_MEEGLE_SPACE_NAME="製品開発"
LARC_MEEGLE_TYPE_NAME="開発要件"

# ── ステータスマッピング ─────────────────────────────────────────────
# get_transitable_states で取得した state_key を設定
# LARC のライフサイクルイベントと Meegle のステータスを対応付ける
LARC_MEEGLE_STATE_START=""          # enqueue 時 → スタート
LARC_MEEGLE_STATE_IN_PROGRESS=""    # run-once 時 → 開発中
LARC_MEEGLE_STATE_DONE=""           # done 時 → 終了
LARC_MEEGLE_STATE_REVIEW=""         # fail 時 → レビュー待ち

# ── 戦略カテゴリ（tags）───────────────────────────────────────────
# カンマ区切り。Meegle Story の tags フィールドに設定する値
LARC_MEEGLE_CATEGORIES="技術基盤,プロダクト,発信,経営基盤"

# ── 週次レビュー設定 ─────────────────────────────────────────────────
# P0 → P1 降格基準: この日数以上コミットがなければ降格提案
LARC_MEEGLE_DEMOTE_THRESHOLD_DAYS=14

# P1 → P0 昇格基準: この日数以内にコミットがあれば昇格提案
LARC_MEEGLE_PROMOTE_THRESHOLD_DAYS=7
