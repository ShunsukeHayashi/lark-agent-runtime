#!/usr/bin/env bash
# larc — Lark Agent Runtime CLI
# Reproduces OpenClaw-compatible disclosure chain on Lark Drive
#
# Usage: larc <command> [options]
#   bootstrap          Load Soul/User/Memory from Lark Drive into local workspace
#   memory <pull|push> Sync memory with Lark Base
#   heartbeat          Record/read system state in Lark Base
#   send <message>     Send message to Lark IM (equivalent to openclaw agent --agent main)
#   task <action>      Lark Project task operations
#   approve <action>   Approval task + raw API helper flow
#   agent <action>     Register/manage Lark agents in OpenClaw format
#   status             Show current connection state and agent list

set -euo pipefail

# ── Configuration ──────────────────────────────────────────────────────────────
LARC_VERSION="0.1.0"
LARC_HOME="${LARC_HOME:-$HOME/.larc}"
LARC_CACHE="$LARC_HOME/cache"
LARC_CONFIG="$LARC_HOME/config.env"
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
LIB_DIR="$SCRIPT_DIR/lib"

# Color definitions
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; BOLD='\033[1m'; RESET='\033[0m'

# ── Helpers ──────────────────────────────────────────────────────────────
log_info()  { echo -e "${BLUE}[larc]${RESET} $*"; }
log_ok()    { echo -e "${GREEN}[larc]${RESET} $*"; }
log_warn()  { echo -e "${YELLOW}[larc]${RESET} $*"; }
log_error() { echo -e "${RED}[larc]${RESET} $*" >&2; }
log_head()  { echo -e "\n${BOLD}${CYAN}▶ $*${RESET}"; }

require_lark_cli() {
  if ! command -v lark-cli &>/dev/null; then
    log_error "lark-cli not found. Install: npm install -g @larksuite/cli"
    exit 1
  fi
}

load_config() {
  if [[ -f "$LARC_CONFIG" ]]; then
    # shellcheck source=/dev/null
    source "$LARC_CONFIG"
  fi
  # Default values for required variables
  LARC_WIKI_SPACE_ID="${LARC_WIKI_SPACE_ID:-}"
  LARC_BASE_APP_TOKEN="${LARC_BASE_APP_TOKEN:-}"
  LARC_DRIVE_FOLDER_TOKEN="${LARC_DRIVE_FOLDER_TOKEN:-}"
  LARC_IM_CHAT_ID="${LARC_IM_CHAT_ID:-}"
  LARC_APPROVAL_CODE="${LARC_APPROVAL_CODE:-}"
  LARC_CACHE_TTL="${LARC_CACHE_TTL:-300}"  # 5 minutes
}

# ── Subcommand dispatch ──────────────────────────────────────────────────
cmd_bootstrap() { source "$LIB_DIR/bootstrap.sh"; cmd_bootstrap "$@"; }
cmd_memory()    { source "$LIB_DIR/memory.sh";    cmd_memory "$@"; }
cmd_heartbeat() { source "$LIB_DIR/heartbeat.sh"; cmd_heartbeat "$@"; }
cmd_send()      { source "$LIB_DIR/send.sh";      cmd_send "$@"; }
cmd_task()      { source "$LIB_DIR/task.sh";      cmd_task "$@"; }
cmd_approve()   { source "$LIB_DIR/approve.sh";   cmd_approve "$@"; }
cmd_agent()     { source "$LIB_DIR/agent.sh";     cmd_agent "$@"; }
cmd_auth()      { source "$LIB_DIR/auth.sh";      cmd_auth "$@"; }
cmd_kg()        { source "$LIB_DIR/knowledge-graph.sh"; cmd_kg "$@"; }
cmd_ingress()   { source "$LIB_DIR/memory.sh"; source "$LIB_DIR/send.sh"; source "$LIB_DIR/ingress.sh"; cmd_ingress "$@"; }

cmd_init() {
  log_head "larc init — Initialize Lark Drive agent workspace"
  require_lark_cli
  mkdir -p "$LARC_HOME" "$LARC_CACHE"

  if [[ -f "$LARC_CONFIG" ]]; then
    log_warn "Existing config found: $LARC_CONFIG"
    read -r -p "Overwrite? [y/N] " ans
    [[ "$ans" != "y" ]] && { log_info "Aborted"; exit 0; }
  fi

  echo ""
  log_info "Enter Lark Drive folder token (e.g., fldcnXXXXXX)"
  log_info "  → Open the target folder in Lark browser and copy the token from the URL"
  read -r -p "DRIVE_FOLDER_TOKEN: " drive_token

  log_info "Enter Lark Base app_token (for memory and config storage)"
  read -r -p "BASE_APP_TOKEN: " base_token

  log_info "Enter IM chat_id for notifications (optional)"
  read -r -p "IM_CHAT_ID: " chat_id

  log_info "Enter Wiki space ID (optional)"
  read -r -p "WIKI_SPACE_ID: " wiki_id

  cat > "$LARC_CONFIG" <<EOF
# larc config — $(date +%Y-%m-%d)
LARC_DRIVE_FOLDER_TOKEN="${drive_token}"
LARC_BASE_APP_TOKEN="${base_token}"
LARC_IM_CHAT_ID="${chat_id}"
LARC_WIKI_SPACE_ID="${wiki_id}"
LARC_CACHE_TTL=300
EOF

  log_ok "Config saved: $LARC_CONFIG"
  log_info "Next step: run 'larc bootstrap' to load context from Lark"
}

cmd_status() {
  log_head "larc status"
  require_lark_cli
  load_config

  echo -e "${BOLD}Version:${RESET} $LARC_VERSION"
  echo -e "${BOLD}Config:${RESET} $LARC_CONFIG"
  echo -e "${BOLD}Cache:${RESET} $LARC_CACHE"
  echo ""

  # lark-cli connection check
  echo -e "${BOLD}Lark connection:${RESET}"
  local identity
  identity=$(lark-cli auth status --jq '.userName' 2>/dev/null || echo "not connected")
  echo -e "  User: $identity"

  # Drive folder check
  if [[ -n "$LARC_DRIVE_FOLDER_TOKEN" ]]; then
    echo -e "  Drive folder: ${GREEN}configured${RESET} ($LARC_DRIVE_FOLDER_TOKEN)"
  else
    echo -e "  Drive folder: ${RED}not set${RESET} (run 'larc init')"
  fi

  # Cache state
  echo ""
  echo -e "${BOLD}Local cache:${RESET}"
  if [[ -d "$LARC_CACHE" ]]; then
    local count
    count=$(find "$LARC_CACHE" -type f 2>/dev/null | wc -l | tr -d ' ')
    echo -e "  Files: $count"
    local latest
    latest=$(find "$LARC_CACHE" -type f -newer "$LARC_CONFIG" 2>/dev/null | head -1)
    [[ -n "$latest" ]] && echo -e "  Last updated: $(stat -f '%Sm' -t '%Y-%m-%d %H:%M' "$latest" 2>/dev/null)"
  else
    echo -e "  No cache"
  fi
}

cmd_help() {
  cat <<EOF

${BOLD}larc${RESET} v${LARC_VERSION} — Lark Agent Runtime CLI
CLI tool for running OpenClaw-compatible agents on Lark Drive

${BOLD}Usage:${RESET}
  larc <command> [options]

${BOLD}Commands:${RESET}
  ${CYAN}init${RESET}                  Initialize and configure Lark Drive workspace
  ${CYAN}bootstrap${RESET}             Load Soul/User/Memory from Lark and expand locally
                          --agent <id>  Target agent ID (default: main)
                          --force       Ignore cache and re-fetch
  ${CYAN}memory pull${RESET}           Sync memory from Lark Base to local
  ${CYAN}memory push${RESET}           Write local memory back to Lark Base
  ${CYAN}memory search${RESET}         Search recent Base-backed memory by keyword
  ${CYAN}heartbeat${RESET}             Record system state to Lark Base
  ${CYAN}send${RESET} "<message>"      Send message to Lark IM
                          (equivalent to: openclaw agent --agent main --json -m)
  ${CYAN}task list${RESET}             List Lark Project tasks
  ${CYAN}task create${RESET}           Create a task
                          --title <text> [--due <date|+1d>]
  ${CYAN}task done${RESET} <id>        Mark a task as done
  ${CYAN}approve list${RESET}          List current approval tasks
  ${CYAN}approve definition${RESET}    Fetch approval definition
  ${CYAN}approve scaffold-package${RESET}
                          Generate approval-definition.json + form.json + extra.json
  ${CYAN}approve create${RESET}        Create approval instance via raw API helper
  ${CYAN}agent list${RESET}            List registered agents
  ${CYAN}agent register${RESET}        Register a new agent in Lark
                          --id <id> --name <name> [--model <model>] [--workspace <desc>] [--chat <chat_id>]
  ${CYAN}auth suggest${RESET} "<text>" Infer required scopes from task description
  ${CYAN}auth check${RESET}            Check current permission state (suggests login if gaps)
  ${CYAN}auth login${RESET}            Issue auth URL for specified scopes
  ${CYAN}approve gate${RESET} [type]   Check execution gate (none|preview|approval) for a task type
  ${CYAN}ingress enqueue${RESET}       Normalize an inbound Lark message and enqueue it for execution
  ${CYAN}ingress list${RESET}          List queued inbound tasks from Base/local cache
  ${CYAN}ingress openclaw${RESET}      Build or dispatch the next-step bundle for an OpenClaw agent
  ${CYAN}ingress next${RESET}          Pull the next actionable queue item for an agent
  ${CYAN}ingress run-once${RESET}      Claim the next actionable queue item for an agent
  ${CYAN}ingress execute-stub${RESET}  Show a placeholder execution plan for an in-progress item
  ${CYAN}ingress execute-apply${RESET} Execute safe adapter actions for an in-progress item
  ${CYAN}ingress followup${RESET}      Show partial items that still need manual follow-up
  ${CYAN}ingress approve${RESET}       Mark a blocked queue item as approved
  ${CYAN}ingress resume${RESET}        Resume an approved queue item into pending state
  ${CYAN}ingress delegate${RESET}      Assign a pending queue item to the best registered specialist agent
  ${CYAN}ingress context${RESET}       Build an execution context bundle with related recent memory
  ${CYAN}ingress handoff${RESET}       Build an agent handoff bundle for a delegated queue item
  ${CYAN}ingress done${RESET}          Mark a delegated or pending queue item as completed
  ${CYAN}ingress fail${RESET}          Mark a delegated or pending queue item as failed
  ${CYAN}kg build${RESET}              Traverse Lark Wiki and index node graph into Base
  ${CYAN}kg query${RESET} "<concept>"  Keyword search over indexed graph; show matches + neighbors
  ${CYAN}kg show${RESET} <token>       Show node details and neighbors from local cache
  ${CYAN}status${RESET}                Show connection state and config

${BOLD}Examples:${RESET}
  larc init
  larc bootstrap --agent main
  larc send "Please draft an expense report"
  larc memory push
  larc memory search --query "approval" --days 14
  larc task create --title "Q2 budget review" --due 2026-04-20
  larc agent register --id finance-bot --name "Finance Agent"
  larc approve scaffold-package --approval-code APPROVAL_CODE --output-dir ./approval-work
  larc approve list
  larc ingress enqueue --text "Please route this expense to approval" --sender ou_xxx --source im
  larc ingress list --agent main
  larc ingress openclaw --agent main --days 14
  larc ingress openclaw --queue-id <id> --execute
  larc ingress openclaw --queue-id <id> --gateway --execute
  larc ingress next --agent crm-agent --days 14
  larc ingress run-once --agent crm-agent --days 14 --dry-run
  larc ingress run-once --queue-id <id> --agent main
  larc ingress execute-stub --queue-id <id>
  larc ingress execute-apply --queue-id <id> --dry-run
  larc ingress followup --agent crm-agent
  larc ingress approve --queue-id <id>
  larc ingress resume --queue-id <id>
  larc ingress delegate --queue-id <id>
  larc ingress context --queue-id <id> --days 14
  larc ingress handoff --queue-id <id> --days 14
  larc ingress done --queue-id <id> --note "Sent to manager and updated CRM"
  larc ingress fail --queue-id <id> --note "Missing required contact scope"

${BOLD}Environment:${RESET}
  LARC_HOME              Config and cache directory (default: ~/.larc)

${BOLD}Config file:${RESET}
  ~/.larc/config.env

EOF
}

# ── Main ────────────────────────────────────────────────────────────────────
main() {
  [[ $# -eq 0 ]] && { cmd_help; exit 0; }

  load_config

  case "$1" in
    init)       shift; cmd_init "$@" ;;
    bootstrap)  shift; require_lark_cli; cmd_bootstrap "$@" ;;
    memory)     shift; require_lark_cli; cmd_memory "$@" ;;
    heartbeat)  shift; require_lark_cli; cmd_heartbeat "$@" ;;
    send)       shift; require_lark_cli; cmd_send "$@" ;;
    task)       shift; require_lark_cli; cmd_task "$@" ;;
    approve)    shift; require_lark_cli; cmd_approve "$@" ;;
    agent)      shift; require_lark_cli; cmd_agent "$@" ;;
    auth)       shift; require_lark_cli; cmd_auth "$@" ;;
    ingress)    shift; require_lark_cli; cmd_ingress "$@" ;;
    kg)         shift; require_lark_cli; cmd_kg "$@" ;;
    status)     shift; cmd_status "$@" ;;
    help|--help|-h) cmd_help ;;
    *)
      log_error "Unknown command: $1"
      cmd_help
      exit 1
      ;;
  esac
}

main "$@"
