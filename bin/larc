#!/usr/bin/env bash
# larc — Lark Agent Runtime CLI
# Reproduces OpenClaw-compatible disclosure chain on Lark Drive
#
# Usage: larc <command> [options]
#   bootstrap          Load Soul/User/Memory from Lark Drive into local workspace
#   memory <pull|push> Sync memory with Lark Base
#   heartbeat          Record/read system state in Lark Base
#   send <message>     Send message to Lark IM (equivalent to openclaw agent --agent main)
#   task <action>      Lark Project task operations
#   approve <action>   Approval task + raw API helper flow
#   agent <action>     Register/manage Lark agents in OpenClaw format
#   status             Show current connection state and agent list

set -euo pipefail

# ── Configuration ──────────────────────────────────────────────────────────────
LARC_VERSION="0.2.0"
LARC_REPO_URL="https://github.com/ShunsukeHayashi/lark-agent-runtime.git"
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
LIB_DIR="$SCRIPT_DIR/lib"
export LIB_DIR LARC_HOME LARC_CACHE LARC_CONFIG LARC_TENANT_ID

# Multi-tenant: each tenant gets an isolated directory under ~/.larc/tenants/<id>/
# Set LARC_TENANT_ID=default for single-tenant (legacy) operation
LARC_TENANT_ID="${LARC_TENANT_ID:-default}"

# Tenant home: env var → tenant-scoped dir → legacy ~/.larc (for LARC_TENANT_ID=default)
if [[ "${LARC_TENANT_ID}" == "default" ]]; then
  LARC_HOME="${LARC_HOME:-$HOME/.larc}"
else
  LARC_HOME="${LARC_HOME:-$HOME/.larc/tenants/${LARC_TENANT_ID}}"
fi

LARC_CACHE="$LARC_HOME/cache"
LARC_CONFIG="$LARC_HOME/config.env"

# Color definitions
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; BOLD='\033[1m'; RESET='\033[0m'

# ── Helpers ──────────────────────────────────────────────────────────────
log_info()  { echo -e "${BLUE}[larc]${RESET} $*"; }
log_ok()    { echo -e "${GREEN}[larc]${RESET} $*"; }
log_warn()  { echo -e "${YELLOW}[larc]${RESET} $*"; }
log_error() { echo -e "${RED}[larc]${RESET} $*" >&2; }
log_head()  { echo -e "\n${BOLD}${CYAN}▶ $*${RESET}"; }

require_lark_cli() {
  if ! command -v lark-cli &>/dev/null; then
    log_warn "lark-cli が見つかりません。自動インストールを試みます..."
    if command -v npm &>/dev/null; then
      if npm install -g @larksuite/cli; then
        log_ok "lark-cli をインストールしました"
      else
        log_error "lark-cli のインストールに失敗しました"
        log_error "手動でインストールしてください: npm install -g @larksuite/cli"
        exit 1
      fi
    else
      log_error "npm が見つかりません。Node.js をインストールしてから再実行してください"
      log_error "Node.js: https://nodejs.org/"
      exit 1
    fi
  fi
}

load_config() {
  # Ensure tenant directory exists
  mkdir -p "$LARC_HOME" "$LARC_CACHE"

  # Load file-based config (env vars already set take precedence)
  if [[ -f "$LARC_CONFIG" ]]; then
    # shellcheck source=/dev/null
    set -a; source "$LARC_CONFIG"; set +a
  fi

  # Load Drive token index (folder/table/doc token map for fast agent lookup)
  local drive_index="$LARC_HOME/drive-index.env"
  if [[ -f "$drive_index" ]]; then
    # shellcheck source=/dev/null
    set -a; source "$drive_index"; set +a
  fi

  # Environment variable overrides (Docker/K8s friendly)
  # Each var: env var wins over config file value, config file wins over empty default
  LARC_DRIVE_FOLDER_TOKEN="${LARC_DRIVE_FOLDER_TOKEN:-}"
  LARC_BASE_APP_TOKEN="${LARC_BASE_APP_TOKEN:-}"
  LARC_IM_CHAT_ID="${LARC_IM_CHAT_ID:-}"
  LARC_WIKI_SPACE_ID="${LARC_WIKI_SPACE_ID:-}"
  LARC_APPROVAL_CODE="${LARC_APPROVAL_CODE:-}"
  LARC_CACHE_TTL="${LARC_CACHE_TTL:-300}"
  LARC_ALLOW_FROM="${LARC_ALLOW_FROM:-}"
  FEISHU_APP_ID="${FEISHU_APP_ID:-}"
  FEISHU_APP_SECRET="${FEISHU_APP_SECRET:-}"
}

# ── Subcommand dispatch ──────────────────────────────────────────────────
cmd_bootstrap() { source "$LIB_DIR/bootstrap.sh"; cmd_bootstrap "$@"; }
cmd_memory()    { source "$LIB_DIR/memory.sh";    cmd_memory "$@"; }
cmd_heartbeat() { source "$LIB_DIR/heartbeat.sh"; cmd_heartbeat "$@"; }
cmd_send()      { source "$LIB_DIR/send.sh";      cmd_send "$@"; }
cmd_task()      { source "$LIB_DIR/task.sh";      cmd_task "$@"; }
cmd_approve()   { source "$LIB_DIR/approve.sh";   cmd_approve "$@"; }
cmd_agent()     { source "$LIB_DIR/agent.sh";     cmd_agent "$@"; }
cmd_auth()      { source "$LIB_DIR/auth.sh";      cmd_auth "$@"; }
cmd_kg()        { source "$LIB_DIR/knowledge-graph.sh"; cmd_kg "$@"; }
cmd_ingress()   { source "$LIB_DIR/memory.sh"; source "$LIB_DIR/send.sh"; source "$LIB_DIR/ingress.sh"; cmd_ingress "$@"; }
cmd_daemon()    { source "$LIB_DIR/worker.sh"; source "$LIB_DIR/daemon.sh"; cmd_daemon "$@"; }
cmd_webhook()   { source "$LIB_DIR/webhook.sh"; cmd_webhook "$@"; }
cmd_worker()    { source "$LIB_DIR/worker.sh"; cmd_worker "$@"; }
cmd_onboard()   { _cmd_onboard "$@"; }
cmd_template()  { _cmd_template "$@"; }
cmd_dashboard() { source "$LIB_DIR/dashboard.sh"; cmd_dashboard "$@"; }
cmd_billing()   { source "$LIB_DIR/billing.sh";   cmd_billing   "$@"; }

cmd_quickstart() {
  # ── LARC Quickstart — zero-to-running in one command ──────────────────────
  # Safe for existing Lark workspaces: only creates new larc-* folders.
  # Never modifies or deletes any pre-existing files or projects.
  # Idempotent: re-running detects existing LARC setup and skips safely.
  #
  # Flags:
  #   --dry-run    Preview what would be created without making changes
  #   --force      Recreate config even if one exists

  require_lark_cli

  local dry_run=false force=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run) dry_run=true; shift ;;
      --force)   force=true;   shift ;;
      *) log_warn "Unknown option: $1"; shift ;;
    esac
  done

  local _R='\033[0;31m' _G='\033[0;32m' _Y='\033[1;33m'
  local _B='\033[0;34m' _C='\033[0;36m' _W='\033[1m' _E='\033[0m'
  _qs_ok()      { echo -e "  ${_G}✓${_E} $*"; }
  _qs_fail()    { echo -e "  ${_R}✗${_E} $*" >&2; }
  _qs_info()    { echo -e "  ${_B}·${_E} $*"; }
  _qs_head()    { echo -e "\n${_W}${_C}▶ $*${_E}"; }
  _qs_skip()    { echo -e "  ${_Y}↷${_E} $*"; }
  _qs_dryrun()  { echo -e "  ${_Y}[dry-run]${_E} $*"; }

  echo ""
  echo -e "${_W}${_C}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${_E}"
  echo -e "${_W}${_C}  LARC Quickstart — Automated Setup${_E}"
  [[ "$dry_run" == "true" ]] && \
  echo -e "${_Y}  DRY-RUN MODE: 変更は行いません${_E}"
  echo -e "${_W}${_C}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${_E}"
  echo ""
  echo -e "  ${_B}※ 既存の Lark ファイル・プロジェクトには一切触れません${_E}"
  echo -e "  ${_B}  LARC 専用フォルダのみ新規作成します${_E}"
  echo ""

  # ── Step 1: Verify lark-cli auth ─────────────────────────────────────────
  _qs_head "Step 1/7 — Lark 認証確認"

  # Sub-check 1a: Is lark-cli configured with an app?
  # Use `config show` (exists in v1.0.11+); `config list` does not exist.
  # Output is a flat JSON {"appId":"cli_...","brand":"lark",...}.
  # Also handle future array format {"apps":[{"appId":"..."},...]} defensively.
  local config_check app_id_configured=""
  config_check=$(lark-cli config show 2>/dev/null || echo "")
  app_id_configured=$(echo "$config_check" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    apps = d.get('apps', [])
    if apps:
        print(apps[0].get('appId', ''))
    else:
        print(d.get('appId', ''))
except Exception:
    pass
" 2>/dev/null || echo "")

  if [[ -z "$app_id_configured" ]]; then
    _qs_info "lark-cli にアプリが登録されていません。今すぐ設定します。"
    echo ""
    echo -e "  ${_W}Lark Developer Console から App ID と App Secret を用意してください。${_E}"
    echo -e "  ${_B}（https://open.larksuite.com/app → 対象アプリ → Credentials & Basic Info）${_E}"
    echo ""

    # Prompt for App ID interactively
    local input_app_id=""
    while [[ -z "$input_app_id" ]]; do
      printf "  App ID を入力してください (cli_...): "
      read -r input_app_id
    done

    # Prompt for App Secret interactively (hidden input)
    local input_app_secret=""
    while [[ -z "$input_app_secret" ]]; do
      printf "  App Secret を入力してください: "
      read -rs input_app_secret
      echo ""
    done

    echo ""
    _qs_info "lark-cli config init を実行中..."
    if echo "$input_app_secret" | lark-cli config init \
        --app-id "$input_app_id" \
        --app-secret-stdin \
        --brand lark 2>&1; then
      app_id_configured="$input_app_id"
      _qs_ok "アプリ登録完了: $app_id_configured"
    else
      _qs_fail "lark-cli config init に失敗しました。App ID / Secret を確認してください。"
      exit 1
    fi
    echo ""
  fi

  # Sub-check 1b: Is user logged in?
  local auth_json user_name user_oid token_status
  auth_json=$(lark-cli auth status 2>/dev/null || echo "{}")
  user_name=$(echo "$auth_json"    | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('userName',''))" 2>/dev/null)
  user_oid=$(echo "$auth_json"     | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('userOpenId',''))" 2>/dev/null)
  token_status=$(echo "$auth_json" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('tokenStatus',''))" 2>/dev/null)

  if [[ "$token_status" != "valid" || -z "$user_name" ]]; then
    _qs_info "Lark アカウントへのログインが必要です。ブラウザで認証します..."
    echo ""
    echo -e "  ${_W}ブラウザが開きます。Lark アカウントでログインしてください。${_E}"
    echo -e "  ${_B}ブラウザが自動で開かない場合は、表示される URL をコピーしてブラウザに貼り付けてください。${_E}"
    echo ""
    # Run auth login directly so the URL appears inline
    lark-cli auth login
    echo ""

    # Re-check after login
    auth_json=$(lark-cli auth status 2>/dev/null || echo "{}")
    user_name=$(echo "$auth_json"    | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('userName',''))" 2>/dev/null)
    token_status=$(echo "$auth_json" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('tokenStatus',''))" 2>/dev/null)

    if [[ "$token_status" != "valid" || -z "$user_name" ]]; then
      _qs_fail "ログインを確認できませんでした。もう一度 'larc quickstart' を実行してください。"
      exit 1
    fi
  fi
  _qs_ok "認証済み: ${user_name}  (app: ${app_id_configured})"

  # ── Step 2: Check for existing LARC setup ────────────────────────────────
  _qs_head "Step 2/7 — 既存 LARC 設定の検出"
  mkdir -p "$LARC_HOME" "$LARC_CACHE"

  local existing_ok=false ws_token="" wd_token="" base_token=""
  if [[ -f "$LARC_CONFIG" && "$force" != "true" ]]; then
    source "$LARC_CONFIG" 2>/dev/null || true
    ws_token="${LARC_DRIVE_FOLDER_TOKEN:-}"
    wd_token="${LARC_WORK_FOLDER_TOKEN:-}"
    base_token="${LARC_BASE_APP_TOKEN:-}"
    if [[ -n "$ws_token" && -n "$base_token" ]]; then
      existing_ok=true
      _qs_skip "既存の設定を検出しました（スキップ可能なステップは省略）"
      _qs_skip "  workspace:   $ws_token"
      _qs_skip "  workdir:     ${wd_token:-(未設定)}"
      _qs_skip "  LARC-memory: $base_token"
    fi
  fi

  if [[ "$existing_ok" == "false" ]]; then
    _qs_info "新規セットアップを開始します"
  fi

  # ── Step 3: Create Drive folder structure ─────────────────────────────────
  _qs_head "Step 3/7 — Lark Drive フォルダ構築"
  _qs_info "既存フォルダ・ファイルには一切影響しません"

  if [[ "$existing_ok" == "true" && -n "$ws_token" ]]; then
    _qs_skip "larc-workspace 既存: $ws_token"
  elif [[ "$dry_run" == "true" ]]; then
    _qs_dryrun "Lark Drive に 'larc-workspace' フォルダを作成する"
    _qs_dryrun "Lark Drive に 'larc-workdir' フォルダを作成する"
    ws_token="(dry-run)"
    wd_token="(dry-run)"
  else
    # Create folders in Drive root.
    # folder_token="" means root directory (per lark-cli schema).
    # Required scope: space:folder:create (NOT drive:drive).
    # Do NOT fetch root_folder/meta first — it triggers unnecessary permission checks.

    _qs_info "larc-workspace フォルダを作成中..."
    local ws_result
    ws_result=$(lark-cli drive files create_folder \
      --data '{"name":"larc-workspace","folder_token":""}' 2>&1)
    ws_token=$(echo "$ws_result" | python3 -c \
      "import sys,json; d=json.load(sys.stdin); print(d.get('data',{}).get('token',''))" 2>/dev/null)
    if [[ -z "$ws_token" ]]; then
      _qs_fail "larc-workspace 作成失敗"
      echo ""
      echo -e "  ${_W}エラー詳細:${_E} $ws_result"
      echo ""
      echo -e "  ${_W}【確認事項】${_E}"
      echo -e "  Developer Console → Permissions & Scopes で"
      echo -e "  ${_C}space:folder:create${_E} が追加・公開済みか確認してください"
      echo -e "  → ${_C}https://open.larksuite.com/app${_E}"
      exit 1
    fi
    _qs_ok "larc-workspace 作成: $ws_token"

    _qs_info "larc-workdir フォルダを作成中..."
    local wd_result
    wd_result=$(lark-cli drive files create_folder \
      --data '{"name":"larc-workdir","folder_token":""}' 2>&1)
    wd_token=$(echo "$wd_result" | python3 -c \
      "import sys,json; d=json.load(sys.stdin); print(d.get('data',{}).get('token',''))" 2>/dev/null)
    if [[ -z "$wd_token" ]]; then
      _qs_fail "larc-workdir 作成失敗: $wd_result"
      exit 1
    fi
    _qs_ok "larc-workdir  作成: $wd_token"
  fi

  # ── Step 4: Create LARC-memory Base ───────────────────────────────────────
  _qs_head "Step 4/7 — LARC-memory Base 構築"

  local queue_tbl="" logs_tbl=""
  if [[ "$existing_ok" == "true" && -n "$base_token" ]]; then
    _qs_skip "LARC-memory Base 既存: $base_token"
    # Fetch existing table IDs
    local existing_tbls
    existing_tbls=$(lark-cli api GET "/open-apis/bitable/v1/apps/${base_token}/tables" 2>/dev/null)
    queue_tbl=$(echo "$existing_tbls" | python3 -c \
      "import sys,json; d=json.load(sys.stdin)
[print(t['table_id']) for t in d.get('data',{}).get('items',[]) if t.get('name')=='agent_queue']" 2>/dev/null | head -1)
    logs_tbl=$(echo "$existing_tbls"  | python3 -c \
      "import sys,json; d=json.load(sys.stdin)
[print(t['table_id']) for t in d.get('data',{}).get('items',[]) if t.get('name')=='agent_logs']" 2>/dev/null | head -1)
    _qs_skip "  agent_queue: ${queue_tbl:-(不明)}"
    _qs_skip "  agent_logs:  ${logs_tbl:-(不明)}"
  elif [[ "$dry_run" == "true" ]]; then
    _qs_dryrun "Lark Base 'LARC-memory' を作成する（5テーブル）"
    base_token="(dry-run)"
  else
    _qs_info "LARC-memory Base を作成中..."
    local base_result
    base_result=$(lark-cli api POST "/open-apis/bitable/v1/apps" \
      --data "{\"name\":\"LARC-memory\",\"folder_token\":\"$ws_token\"}" 2>&1)
    base_token=$(echo "$base_result" | python3 -c \
      "import sys,json; d=json.load(sys.stdin); print(d.get('data',{}).get('app',{}).get('app_token',''))" 2>/dev/null)
    [[ -z "$base_token" ]] && { _qs_fail "Base 作成失敗: $base_result"; exit 1; }
    _qs_ok "LARC-memory Base: $base_token"

    for tbl_name in agent_queue agent_logs agent_memory agents_registry wiki_knowledge_graph; do
      local tbl_result tbl_id
      tbl_result=$(lark-cli api POST "/open-apis/bitable/v1/apps/${base_token}/tables" \
        --data "{\"table\":{\"name\":\"${tbl_name}\"}}" 2>&1)
      tbl_id=$(echo "$tbl_result" | python3 -c \
        "import sys,json; d=json.load(sys.stdin); print(d.get('data',{}).get('table_id',''))" 2>/dev/null)
      if [[ -n "$tbl_id" ]]; then
        _qs_ok "  ${tbl_name} → $tbl_id"
        [[ "$tbl_name" == "agent_queue" ]] && queue_tbl="$tbl_id"
        [[ "$tbl_name" == "agent_logs"  ]] && logs_tbl="$tbl_id"
      else
        _qs_fail "  ${tbl_name} 作成失敗"
      fi
    done
  fi

  # ── Step 5: Create identity docs ─────────────────────────────────────────
  _qs_head "Step 5/7 — アイデンティティドキュメント作成"

  local today
  today=$(date +%Y-%m-%d)

  if [[ "$dry_run" == "true" ]]; then
    for doc_name in SOUL USER MEMORY HEARTBEAT; do
      _qs_dryrun "larc-workspace/ に '${doc_name}' ドキュメントを作成する"
    done
  else
    local ws_files
    ws_files=$(lark-cli drive files list \
      --params "{\"folder_token\":\"${ws_token}\"}" 2>/dev/null)

    declare -A doc_md
    doc_md["SOUL"]="# SOUL — Agent Identity

This agent operates as a trusted AI assistant inside your Lark workspace.

## Principles
- **Permission-first**: always verify scopes before acting
- **Transparent**: log every action to agent_logs
- **Minimal**: request only the permissions this task requires
- **Human-in-the-loop**: stop and ask when authority is unclear

_Created by larc quickstart on ${today}_"

    doc_md["USER"]="# USER — User Profile

## Identity
- **Name**: ${user_name}
- **Lark OpenID**: ${user_oid}
- **Setup date**: ${today}

## Preferences
- Language: Japanese
- Timezone: Asia/Tokyo

_Personalize this file to guide agent behavior._"

    doc_md["MEMORY"]="# MEMORY — Long-term Memory

_Initialized by larc quickstart on ${today}_

This file accumulates what the agent has learned about your operations.
Use \`larc memory push\` to add new entries.

## Entry format
\`\`\`
[YYYY-MM-DD] topic: content
\`\`\`"

    doc_md["HEARTBEAT"]="# HEARTBEAT — System State

_Initialized by larc quickstart on ${today}_

## Status: ✅ OK
- Agent: main
- Initialized: ${today}
- Last bootstrap: —

_Updated automatically by \`larc heartbeat\`_"

    for doc_name in SOUL USER MEMORY HEARTBEAT; do
      local existing_tok
      existing_tok=$(echo "$ws_files" | python3 -c "
import sys,json
d=json.load(sys.stdin)
for f in d.get('data',{}).get('files',[]):
  n=f.get('name','')
  if n=='${doc_name}' or n=='${doc_name}.md':
    print(f.get('token','')); break
" 2>/dev/null)
      if [[ -n "$existing_tok" ]]; then
        _qs_skip "${doc_name} 既存 → $existing_tok"
      else
        local doc_result doc_tok
        doc_result=$(lark-cli docs +create \
          --title "$doc_name" \
          --folder-token "$ws_token" \
          --markdown "${doc_md[$doc_name]}" 2>&1)
        doc_tok=$(echo "$doc_result" | python3 -c \
          "import sys,json; d=json.load(sys.stdin); print(d.get('data',{}).get('doc_id',''))" 2>/dev/null)
        [[ -n "$doc_tok" ]] && _qs_ok "${doc_name} 作成 → $doc_tok" \
                             || _qs_fail "${doc_name} 作成失敗"
      fi
    done
  fi

  # ── Step 6: Write config ──────────────────────────────────────────────────
  _qs_head "Step 6/7 — 設定ファイル生成"

  local chat_id="${LARC_IM_CHAT_ID:-}"

  if [[ "$dry_run" == "true" ]]; then
    _qs_dryrun "$LARC_CONFIG を生成する"
    _qs_dryrun "$LARC_HOME/drive-index.env を生成する"
  else
    cat > "$LARC_CONFIG" << CFGEOF
# larc config — ${today}
# Generated by: larc quickstart
LARC_DRIVE_FOLDER_TOKEN="${ws_token}"
LARC_WORK_FOLDER_TOKEN="${wd_token}"
LARC_BASE_APP_TOKEN="${base_token}"
LARC_IM_CHAT_ID="${chat_id}"
LARC_CACHE_TTL=300
# Pinned table IDs
LARC_QUEUE_TABLE_ID="${queue_tbl}"
LARC_LOG_TABLE_ID="${logs_tbl}"
LARC_LARK_USER_OPEN_ID="${user_oid}"
LARC_LARK_USER_NAME="${user_name}"
LARC_LARK_TOKEN_STATUS="valid"
CFGEOF
    _qs_ok "config.env → $LARC_CONFIG"

    cat > "$LARC_HOME/drive-index.env" << IDXEOF
# LARC Drive Index — generated by larc quickstart ${today}
LARC_DRIVE_FOLDER_TOKEN="${ws_token}"
LARC_WORK_FOLDER_TOKEN="${wd_token}"
LARC_TBL_QUEUE="${queue_tbl}"
LARC_TBL_LOGS="${logs_tbl}"
IDXEOF
    _qs_ok "drive-index.env → $LARC_HOME/drive-index.env"

    # Reload
    set -a; source "$LARC_CONFIG"; set +a
  fi

  # ── Step 7: Register main agent ──────────────────────────────────────────
  _qs_head "Step 7/7 — メインエージェント登録"

  if [[ "$dry_run" == "true" ]]; then
    _qs_dryrun "LARC-memory に 'main' エージェントを登録する"
  else
    local existing_agent
    existing_agent=$(larc agent list 2>/dev/null | grep "^main\b" | head -1 || echo "")
    if [[ -n "$existing_agent" ]]; then
      _qs_skip "main エージェント既登録"
    else
      local reg_out reg_ok=false
      for attempt in 1 2 3; do
        reg_out=$(larc agent register \
          --id   main \
          --name "Main Agent" \
          --model "claude-sonnet-4-6" \
          --workspace "General-purpose Lark workspace agent" \
          --chat  "${chat_id:-}" 2>&1)
        if [[ $? -eq 0 ]]; then
          reg_ok=true
          break
        fi
        [[ $attempt -lt 3 ]] && { _qs_info "登録リトライ中 (${attempt}/3)..."; sleep 2; }
      done
      $reg_ok \
        && _qs_ok "main エージェント登録完了" \
        || { _qs_fail "エージェント登録に失敗しました"; echo "$reg_out" | tail -3; }
    fi
  fi

  # ── Final: Bootstrap verification ────────────────────────────────────────
  if [[ "$dry_run" != "true" ]]; then
    echo ""
    _qs_head "動作確認"
    local boot_out
    boot_out=$(larc bootstrap --agent main --force 2>&1)
    if echo "$boot_out" | grep -q "Done:"; then
      _qs_ok "bootstrap 完了 — SOUL/USER/MEMORY/HEARTBEAT 読み込み成功"
    else
      _qs_fail "bootstrap に問題があります"
      echo "$boot_out" | tail -5
    fi
  fi

  # ── Success summary ────────────────────────────────────────────────────────
  echo ""
  if [[ "$dry_run" == "true" ]]; then
    echo -e "${_Y}${_W}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${_E}"
    echo -e "${_Y}${_W}  DRY-RUN 完了 — 上記が実行される予定です${_E}"
    echo -e "${_Y}${_W}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${_E}"
    echo ""
    echo -e "  実際に実行するには: ${_C}larc quickstart${_E}"
  else
    echo -e "${_G}${_W}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${_E}"
    echo -e "${_G}${_W}  セットアップ完了！${_E}"
    echo -e "${_G}${_W}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${_E}"
    echo ""
    echo -e "  ユーザー:     ${user_name}"
    echo -e "  Workspace:    ${ws_token}"
    echo -e "  Workdir:      ${wd_token}"
    echo -e "  LARC-memory:  ${base_token}"
    echo ""
    echo -e "${_W}次にできること:${_E}"
    echo -e "  ${_C}larc status${_E}                            # 状態確認"
    echo -e "  ${_C}larc ingress enqueue --text '依頼内容'${_E}  # タスクを送る"
    echo -e "  ${_C}larc ingress run-once${_E}                  # 次のタスクを処理"
    echo -e "  ${_C}larc daemon start${_E}                      # 常駐デーモン起動"
    echo ""
    echo -e "  ${_B}Lark Drive に larc-workspace/ と larc-workdir/ が作成されました${_E}"
    echo -e "  ${_B}既存のファイルやプロジェクトには変更を加えていません${_E}"
    echo ""
  fi
}

_cmd_onboard() {
  log_head "larc onboard — Guided setup wizard (tenant: ${LARC_TENANT_ID})"
  require_lark_cli

  echo ""
  echo -e "${BOLD}Step 1: Lark Developer Console でアプリを作成${RESET}"
  echo "  URL: https://open.larksuite.com/app  (または Feishu: https://open.feishu.cn/app)"
  echo "  必要な権限:"
  echo "    im:message        メッセージ送受信"
  echo "    drive:drive       Drive 読み書き"
  echo "    base:app          Base 操作"
  echo "    wiki:wiki         Wiki 検索（任意）"
  echo "    approval:approval 承認フロー（任意）"
  echo ""
  read -r -p "App ID を入力 (cli_xxx...): " app_id
  [[ -z "$app_id" ]] && { log_error "App ID は必須です"; return 1; }

  read -r -s -p "App Secret を入力: " app_secret
  echo ""
  [[ -z "$app_secret" ]] && { log_error "App Secret は必須です"; return 1; }

  # Connection test
  echo ""
  log_info "接続テスト中..."
  if FEISHU_APP_ID="$app_id" FEISHU_APP_SECRET="$app_secret" \
      lark-cli auth status &>/dev/null; then
    log_ok "Lark 接続成功"
  else
    log_warn "接続確認できませんでした（続行します）"
  fi

  echo ""
  echo -e "${BOLD}Step 2: Lark Drive フォルダトークン${RESET}"
  echo "  Lark Drive で LARC 用フォルダを作成し、URL からトークンをコピー"
  echo "  例: https://drive.larksuite.com/drive/folder/fldcnXXXXXX → fldcnXXXXXX"
  read -r -p "Drive フォルダトークン: " drive_token
  [[ -z "$drive_token" ]] && { log_error "Drive トークンは必須です"; return 1; }

  echo ""
  echo -e "${BOLD}Step 3: Lark Base アプリトークン${RESET}"
  echo "  LARC メモリ・キュー保存用の Base アプリを作成し、URL からトークンをコピー"
  echo "  例: https://base.larksuite.com/base/bascnXXXXXX → bascnXXXXXX"
  read -r -p "Base アプリトークン: " base_token
  [[ -z "$base_token" ]] && { log_error "Base トークンは必須です"; return 1; }

  echo ""
  echo -e "${BOLD}Step 4: IM チャット ID (任意)${RESET}"
  echo "  エージェントが通知を送る Lark チャットの ID"
  echo "  チャットURLの oc_ で始まる部分、または空 Enter でスキップ"
  read -r -p "IM チャット ID: " chat_id

  echo ""
  echo -e "${BOLD}Step 5: Wiki スペース ID (任意)${RESET}"
  read -r -p "Wiki スペース ID: " wiki_id

  echo ""
  echo -e "${BOLD}Step 6: 承認フローコード (任意)${RESET}"
  read -r -p "Lark Approval コード: " approval_code

  # Write config
  mkdir -p "$LARC_HOME" "$LARC_CACHE"
  cat > "$LARC_CONFIG" <<EOF
# larc config — tenant: ${LARC_TENANT_ID} — $(date +%Y-%m-%d)
FEISHU_APP_ID="${app_id}"
FEISHU_APP_SECRET="${app_secret}"
LARC_DRIVE_FOLDER_TOKEN="${drive_token}"
LARC_BASE_APP_TOKEN="${base_token}"
LARC_IM_CHAT_ID="${chat_id}"
LARC_WIKI_SPACE_ID="${wiki_id}"
LARC_APPROVAL_CODE="${approval_code}"
LARC_CACHE_TTL=300
EOF

  log_ok "設定保存: $LARC_CONFIG"

  # Bootstrap
  echo ""
  log_info "エージェントコンテキストをロード中..."
  larc bootstrap --agent main || log_warn "bootstrap は後で実行してください"

  # Register default agent
  log_info "デフォルトエージェントを登録中..."
  larc agent register --id main --name "LARC Main Agent" 2>/dev/null || true

  # Start daemon
  echo ""
  log_info "デーモンを起動中..."
  larc daemon start

  echo ""
  log_ok "セットアップ完了！"
  # Optional: deploy an agent template
  echo ""
  echo -e "${BOLD}Step 7: エージェントテンプレートを展開 (任意)${RESET}"
  echo "  利用可能テンプレート: expense / minutes / crm / approval-agent / recruitment"
  read -r -p "テンプレート名 (空 Enter でスキップ): " tmpl_name

  if [[ -n "$tmpl_name" ]]; then
    larc template deploy --name "$tmpl_name" --agent main 2>/dev/null && \
      log_ok "テンプレート '$tmpl_name' を展開しました" || \
      log_warn "テンプレート展開をスキップ（後で 'larc template deploy --name $tmpl_name' で実行）"
  fi

  echo ""
  log_ok "セットアップ完了！"
  echo ""
  echo "  次のステップ:"
  echo "   1. Lark でエージェントBot をチャットに追加"
  echo "   2. 'こんにちは' と送信してテスト"
  echo "   3. larc daemon status で稼働確認"
  echo "   4. larc template list で利用可能テンプレートを確認"
  echo ""
}

_cmd_template() {
  local subcmd="${1:-help}"
  shift || true

  local templates_dir="${LIB_DIR}/../agent-workspace/templates"
  # Resolve absolute path
  templates_dir="$(cd "$templates_dir" 2>/dev/null && pwd || echo "$templates_dir")"

  case "$subcmd" in
    list)
      echo ""
      echo -e "${BOLD}Available LARC agent templates:${RESET}"
      echo ""
      if [[ -d "$templates_dir" ]]; then
        for tdir in "$templates_dir"/*/; do
          local tname
          tname=$(basename "$tdir")
          [[ "$tname" == "test" ]] && continue
          local soul_desc=""
          if [[ -f "$tdir/SOUL.md" ]]; then
            soul_desc=$(grep "^## ミッション" -A 1 "$tdir/SOUL.md" 2>/dev/null | tail -1 | sed 's/^[[:space:]]*//')
            [[ -z "$soul_desc" ]] && soul_desc=$(grep "^- 役割:" "$tdir/SOUL.md" 2>/dev/null | head -1 | sed 's/.*: //')
          fi
          printf "  %-20s %s\n" "$tname" "$soul_desc"
        done
      else
        log_warn "Templates directory not found: $templates_dir"
      fi
      echo ""
      echo "  Deploy: larc template deploy --name <name> [--agent <agent-id>]"
      echo ""
      ;;

    deploy)
      local tname="" agent_id="main"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --name)  tname="$2";    shift 2 ;;
          --agent) agent_id="$2"; shift 2 ;;
          *) shift ;;
        esac
      done

      [[ -z "$tname" ]] && { log_error "Usage: larc template deploy --name <template>"; return 1; }

      local src="$templates_dir/$tname"
      [[ -d "$src" ]] || { log_error "Template '$tname' not found. Run 'larc template list' to see options."; return 1; }

      local dest="${LARC_HOME}/workspace/${agent_id}"
      mkdir -p "$dest"

      cp -n "$src/SOUL.md"   "$dest/SOUL.md"   2>/dev/null && log_ok "Deployed SOUL.md → $dest/" || log_info "SOUL.md already exists, skipped"
      cp -n "$src/USER.md"   "$dest/USER.md"   2>/dev/null && log_ok "Deployed USER.md → $dest/" || log_info "USER.md already exists, skipped"
      cp -n "$src/MEMORY.md" "$dest/MEMORY.md" 2>/dev/null && log_ok "Deployed MEMORY.md → $dest/" || log_info "MEMORY.md already exists, skipped"

      log_ok "Template '$tname' deployed for agent '$agent_id'"
      log_info "Edit $dest/SOUL.md to customize agent identity"
      log_info "Edit $dest/USER.md to set user profile and notification channels"
      ;;

    help|*)
      echo ""
      echo -e "${BOLD}larc template${RESET} — Agent template management"
      echo ""
      echo "  larc template list                        List available templates"
      echo "  larc template deploy --name <name>        Deploy template for main agent"
      echo "  larc template deploy --name <name> --agent <id>  Deploy for specific agent"
      echo ""
      echo "  Templates: expense · minutes · crm · approval-agent · recruitment"
      echo ""
      ;;
  esac
}

cmd_init() {
  log_head "larc init — Initialize Lark Drive agent workspace"
  require_lark_cli
  mkdir -p "$LARC_HOME" "$LARC_CACHE"

  if [[ -f "$LARC_CONFIG" ]]; then
    log_warn "Existing config found: $LARC_CONFIG"
    read -r -p "Overwrite? [y/N] " ans
    [[ "$ans" != "y" ]] && { log_info "Aborted"; exit 0; }
  fi

  echo ""
  log_info "Enter Lark Drive folder token (e.g., fldcnXXXXXX)"
  log_info "  → Open the target folder in Lark browser and copy the token from the URL"
  read -r -p "DRIVE_FOLDER_TOKEN: " drive_token

  log_info "Enter Lark Base app_token (for memory and config storage)"
  read -r -p "BASE_APP_TOKEN: " base_token

  log_info "Enter IM chat_id for notifications (optional)"
  read -r -p "IM_CHAT_ID: " chat_id

  log_info "Enter Wiki space ID (optional)"
  read -r -p "WIKI_SPACE_ID: " wiki_id

  cat > "$LARC_CONFIG" <<EOF
# larc config — $(date +%Y-%m-%d)
LARC_DRIVE_FOLDER_TOKEN="${drive_token}"
LARC_BASE_APP_TOKEN="${base_token}"
LARC_IM_CHAT_ID="${chat_id}"
LARC_WIKI_SPACE_ID="${wiki_id}"
LARC_CACHE_TTL=300
EOF

  log_ok "Config saved: $LARC_CONFIG"
  log_info "Next step: run 'larc bootstrap' to load context from Lark"
}

cmd_status() {
  log_head "larc status"
  require_lark_cli
  load_config

  echo -e "${BOLD}Version:${RESET} $LARC_VERSION"
  echo -e "${BOLD}Tenant:${RESET}  $LARC_TENANT_ID"
  echo -e "${BOLD}Home:${RESET}    $LARC_HOME"
  echo -e "${BOLD}Config:${RESET}  $LARC_CONFIG"
  echo -e "${BOLD}Cache:${RESET}   $LARC_CACHE"
  echo ""

  # lark-cli connection check
  echo -e "${BOLD}Lark connection:${RESET}"
  local identity
  identity=$(lark-cli auth status 2>&1 | jq -r '.userName' 2>/dev/null || echo "not connected")
  echo -e "  User: $identity"

  # Drive folder check
  if [[ -n "$LARC_DRIVE_FOLDER_TOKEN" ]]; then
    echo -e "  Drive folder: ${GREEN}configured${RESET} ($LARC_DRIVE_FOLDER_TOKEN)"
  else
    echo -e "  Drive folder: ${RED}not set${RESET} (run 'larc init')"
  fi

  # Cache state
  echo ""
  echo -e "${BOLD}Local cache:${RESET}"
  if [[ -d "$LARC_CACHE" ]]; then
    local count
    count=$(find "$LARC_CACHE" -type f 2>/dev/null | wc -l | tr -d ' ')
    echo -e "  Files: $count"
    local latest
    latest=$(find "$LARC_CACHE" -type f -newer "$LARC_CONFIG" 2>/dev/null | head -1)
    [[ -n "$latest" ]] && echo -e "  Last updated: $(stat -f '%Sm' -t '%Y-%m-%d %H:%M' "$latest" 2>/dev/null)"
  else
    echo -e "  No cache"
  fi
}

